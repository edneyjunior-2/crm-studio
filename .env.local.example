# CRM Studio — variáveis de ambiente
# Copie para .env.local e preencha com as credenciais do PRÓPRIO projeto.
# NÃO reutilizar as credenciais da Aurum — o CRM Studio é um projeto separado (multi-tenant).
#
# Convenção dos comentários:
#   [OBRIGATÓRIA]  — o app (ou o módulo) NÃO funciona sem ela.
#   [RECOMENDADA]  — tem fallback/default, mas configure em produção.
#   [OPCIONAL]     — só necessária se for usar o módulo indicado.

# ─── Supabase ───────────────────────────────────────────────────────────────
# Criar um projeto NOVO dedicado ao CRM Studio.
NEXT_PUBLIC_SUPABASE_URL=          # [OBRIGATÓRIA]
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # [OBRIGATÓRIA]
SUPABASE_SERVICE_ROLE_KEY=         # [OBRIGATÓRIA] server only — NUNCA expor com NEXT_PUBLIC_ (bypassa RLS)

# ─── App / URLs ─────────────────────────────────────────────────────────────
# URL pública do app. [RECOMENDADA] — sem ela, fallback 'https://app.crmstudio.com.br'
# (usado em links de e-mail, convites e callbacks de auth).
NEXT_PUBLIC_SITE_URL=

# ─── Health check ───────────────────────────────────────────────────────────
# Token do health check (/api/health). [RECOMENDADA] em produção.
HEALTH_CHECK_TOKEN=

# ─── Cron (Vercel Cron) ─────────────────────────────────────────────────────
# Vercel Cron envia Authorization: Bearer ${CRON_SECRET}.
# [OBRIGATÓRIA] em produção: sem ele as rotas /api/cron/* rejeitam tudo (401) e
# o acompanhamento automático de processos e a purga de canceladas nunca rodam.
CRON_SECRET=

# ─── Vigia dos crons de sincronização ───────────────────────────────────────
# Ping fire-and-forget (src/lib/healthcheck-ping.ts) pra um heartbeat externo
# (ex.: healthchecks.io) a cada execução — prova que a Vercel disparou o cron,
# mesmo se a plataforma inteira estiver fora do ar (cenário que um vigia
# rodando na própria Vercel não detecta sozinho). [OPCIONAL] — sem a URL, o
# ping é no-op; o vigia interno (cron_execucoes) funciona independente disso.
HEALTHCHECKS_URL_DATAJUD=
HEALTHCHECKS_URL_DJEN=

# ─── Asaas (cobrança / billing) ─────────────────────────────────────────────
# [OBRIGATÓRIA] para o módulo de billing — src/lib/asaas.ts lança erro se faltar.
ASAAS_API_KEY=
ASAAS_BASE_URL=                    # ex.: https://api.asaas.com/v3 (prod) ou https://api-sandbox.asaas.com/v3
# [OBRIGATÓRIA] para receber webhooks do Asaas — /api/asaas/webhook rejeita sem ela.
ASAAS_WEBHOOK_TOKEN=

# ─── E-mail (Resend) ────────────────────────────────────────────────────────
# [RECOMENDADA] — sem ela os e-mails (convites, alertas, contato) NÃO são enviados (apenas warn em log).
RESEND_API_KEY=
# Remetente. [OPCIONAL] — default 'CRM Studio <nao-responda@crmstudio.com.br>'.
EMAIL_FROM=
# Destinatário do formulário de contato. [OPCIONAL] — default 'edneyjuniords@gmail.com'.
CONTATO_EMAIL=
# Destinatário dos alertas internos do cron de purga. [OPCIONAL] — default 'edneyjuniords@gmail.com'.
ALERTA_EMAIL=

# ─── Anthropic (triagem de bug reports) ─────────────────────────────────────
# [OPCIONAL] — usada em /api/bug-report para classificar/resumir relatos via Claude.
ANTHROPIC_API_KEY=

# ─── GitHub (abrir issue a partir de bug report) ────────────────────────────
# Personal Access Token. [OPCIONAL] — sem ele /api/admin/bugs/[id]/trigger retorna 500.
GITHUB_PAT=

# ─── Google Calendar — Service Account ──────────────────────────────────────
# [OPCIONAL] — só se for usar o módulo de calendário via Service Account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
# E-mail do usuário Workspace impersonado (domain-wide delegation). [OPCIONAL] — fallback de subject.
GOOGLE_IMPERSONATE_EMAIL=

# ─── Google Calendar — OAuth (fluxo por usuário) ────────────────────────────
# [OPCIONAL] — só se for usar o calendário via OAuth (src/lib/google/calendar.ts).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── Google Maps (autocomplete de endereço) ────────────────────────────────
# [OPCIONAL] — sem ela o componente de autocomplete de endereço fica oculto.
# Exposta no client (NEXT_PUBLIC_): restrinja por domínio/HTTP referrer no console do Google.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── ZapSign (assinatura eletrônica de contratos) ──────────────────────────
# Credencial GLOBAL da plataforma (não por tenant), mesmo padrão de Asaas/Resend.
# [OBRIGATÓRIA] para "Enviar para assinatura" — src/lib/zapsign.ts lança erro se faltar.
ZAPSIGN_API_KEY=
# Token fixo nosso, cadastrado como query string na URL do webhook no painel
# ZapSign (?token=...). [OBRIGATÓRIA] para receber o callback de assinatura —
# /api/webhooks/zapsign rejeita sem ela.
ZAPSIGN_WEBHOOK_TOKEN=

# ─── DataJud / CNJ (módulo Processos — advocacia) ──────────────────────────
# [OPCIONAL] — na ausência, o código usa a chave PÚBLICA oficial do CNJ.
# Defina apenas se quiser sobrescrever (ex.: chave própria).
DATAJUD_API_KEY=

# ─── Looker Studio (painel de Ads — platform-admin) ────────────────────────
# [OPCIONAL] — sem ela, /admin/ads mostra um card com instruções de configuração.
# URL de EMBED do relatório (Looker Studio → Compartilhar → Incorporar relatório),
# não a URL normal do report. Formato: https://lookerstudio.google.com/embed/reporting/<id>/page/<p>
# Métrica da campanha do próprio CRM Studio — não é por-tenant.
# Exposta no client (NEXT_PUBLIC_): é só a URL do embed, sem credenciais.
NEXT_PUBLIC_LOOKER_ADS_URL=

# ─── Google Analytics 4 / Google Ads (tracking do site de marketing) ───────
# [RECOMENDADA] — sem ela, <Ga/> (src/components/analytics/ga.tsx) não
# renderiza nada e o GA fica desligado (no-op seguro em dev/preview).
# Property do GA4, formato G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=
# [OPCIONAL] — ID/label de conversão do Google Ads, formato
# 'AW-XXXXXXXXX/AbC-D_efG-h'. Sem ela, dispara só o evento GA4
# 'trial_iniciado' (sem a tag de conversão do Ads). Ver docs/lancamento/tracking-plano.md.
NEXT_PUBLIC_ADS_CONVERSION=
