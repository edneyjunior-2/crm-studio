# CRM Studio — variáveis de ambiente
# Copie para .env.local e preencha com as credenciais do PRÓPRIO projeto.
# NÃO reutilizar as credenciais da Aurum — o CRM Studio é um projeto separado (multi-tenant).

# Supabase — criar um projeto NOVO dedicado ao CRM Studio
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server only — NUNCA expor com NEXT_PUBLIC_

# URL pública do app
NEXT_PUBLIC_SITE_URL=

# Token do health check (/api/health)
HEALTH_CHECK_TOKEN=

# Google Calendar via Service Account (opcional — só se for usar o módulo de calendário)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# DataJud / CNJ (módulo Processos — advocacia)
# Opcional: na ausência, o código usa a chave PÚBLICA oficial do CNJ.
# Defina apenas se quiser sobrescrever (ex.: chave própria).
DATAJUD_API_KEY=

# Cron seguro (Vercel Cron envia Authorization: Bearer ${CRON_SECRET}).
# OBRIGATÓRIO em produção: sem ele a rota /api/cron/* rejeita tudo (401) e
# o acompanhamento automático de processos nunca roda.
CRON_SECRET=
